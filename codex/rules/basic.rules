# Codex exec policy rules approximating .claude/settings.json allowlist.
# Place under codex/rules/ and restart Codex.

# Python + static checks/tests
prefix_rule(pattern = ["python", "-c"], decision = "allow")
prefix_rule(pattern = ["python", "-m", "py_compile"], decision = "allow")
prefix_rule(pattern = ["python", "-m", "pyright"], decision = "allow")
prefix_rule(pattern = ["python", "-m", "pytest"], decision = "allow")
prefix_rule(pattern = [".venv/bin/python", "-c"], decision = "allow")
prefix_rule(pattern = [".venv/bin/python", "-m", "py_compile"], decision = "allow")
prefix_rule(pattern = [".venv/bin/python", "-m", "pyright"], decision = "allow")
prefix_rule(pattern = [".venv/bin/python", "-m", "pytest"], decision = "allow")
prefix_rule(pattern = ["pyright"], decision = "allow")
prefix_rule(pattern = ["pytest"], decision = "allow")

# TypeScript / frontend checks
prefix_rule(pattern = ["npx", "tsc"], decision = "allow")
prefix_rule(pattern = ["npx", "--package=typescript", "tsc"], decision = "allow")
prefix_rule(pattern = ["npm", "run", "lint"], decision = "allow")
prefix_rule(pattern = ["npm", "run", "lint-fix"], decision = "allow")

# VCS + GitHub CLI
prefix_rule(pattern = ["git"], decision = "allow")
prefix_rule(pattern = ["gh", "pr"], decision = "allow")

# Common read-only shell commands
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["cat"], decision = "allow")
prefix_rule(pattern = ["head"], decision = "allow")
prefix_rule(pattern = ["tail"], decision = "allow")
prefix_rule(pattern = ["grep"], decision = "allow")
prefix_rule(pattern = ["rg"], decision = "allow")
prefix_rule(pattern = ["wc"], decision = "allow")
prefix_rule(pattern = ["pwd"], decision = "allow")
prefix_rule(pattern = ["tree"], decision = "allow")
prefix_rule(pattern = ["file"], decision = "allow")
prefix_rule(pattern = ["echo"], decision = "allow")

# File/permission utilities
prefix_rule(pattern = ["chmod"], decision = "allow")
prefix_rule(pattern = ["mkdir", "-p"], decision = "allow")

# Project tooling
prefix_rule(pattern = ["ty"], decision = "allow")
prefix_rule(pattern = ["ruff"], decision = "allow")
