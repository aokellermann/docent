{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Docent",
  "colors": {
    "primary": "#7687fa",
    "light": "#dae4fb",
    "dark": "#3f50c2"
  },
  "favicon": "/images/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["get-started/introduction", "get-started/quickstart"]
          },
          {
            "group": "Tutorials",
            "pages": [
              "tutorials/ingesting-transcripts",
              "tutorials/search-and-clustering"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/transcript-schema",
              "concepts/framegrid",
              {
                "group": "Customization",
                "pages": [
                  "concepts/environment-variables",
                  "concepts/llm-prefs"
                ]
              },
              "concepts/app-architecture"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/TransluceAI/docent",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo.png",
    "dark": "/images/logo.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:kevin@transluce.org"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Home",
      "href": "https://transluce.org"
    }
  },
  "footer": {
    "socials": {
      "website": "https://transluce.org",
      "x": "https://x.com/TransluceAI",
      "github": "https://github.com/TransluceAI",
      "linkedin": "https://linkedin.com/company/transluce"
    }
  }
}
